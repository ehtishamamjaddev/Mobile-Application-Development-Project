<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:background="@color/bg_primary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore"
            android:textColor="@color/text_primary"
            style="@style/TextAppearance.AU.Title"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sharp bottom border for Toolbar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- Header Text Block -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse by Skill Area"
            style="@style/TextAppearance.AU.Title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Find mentors by what you need"
            style="@style/TextAppearance.AU.Caption"
            android:textColor="@color/text_tertiary" />
    </LinearLayout>

    <!-- Categories ListView -->
    <ListView
        android:id="@+id/categories_listview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/border_light"
        android:dividerHeight="1dp"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>
