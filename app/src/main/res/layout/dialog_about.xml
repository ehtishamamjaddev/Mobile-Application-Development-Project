<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_elevated_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_logo"
            app:tint="@color/accent_primary"
            android:contentDescription="Logo"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"
            style="@style/TextAppearance.AU.Heading" />

        <!-- Tagline -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textColor="@color/accent_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            style="@style/TextAppearance.AU.Subtitle" />

        <!-- Description with full credits -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_description"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"
            style="@style/TextAppearance.AU.Body" />

        <!-- Close Button -->
        <TextView
            android:id="@+id/btn_close_about"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/close"
            android:gravity="center"
            style="@style/PrimaryButton" />

    </LinearLayout>
</ScrollView>
