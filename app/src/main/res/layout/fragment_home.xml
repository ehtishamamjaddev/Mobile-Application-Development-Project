<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Toolbar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:background="@color/bg_primary">

                <!-- Logo -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_logo"
                    app:tint="@color/accent_primary"
                    android:contentDescription="Logo" />

                <!-- Title -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="@dimen/space_sm"
                    style="@style/TextAppearance.AU.Title" />

                <!-- Notification Bell -->
                <ImageView
                    android:id="@+id/btn_notification_bell"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Notifications" />
            </LinearLayout>

            <!-- Sharp bottom border for Toolbar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light" />

            <!-- Greeting Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardBackgroundColor="@color/accent_primary"
                app:cardElevation="0dp">

                <!-- FrameLayout for drawing decorative circles -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_lg">

                    <!-- Decorative Circle 1 (10% alpha white) -->
                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="-40dp"
                        android:background="@drawable/bg_chip_skill"
                        android:backgroundTint="#1AFFFFFF" />

                    <!-- Decorative Circle 2 (10% alpha white) -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="30dp"
                        android:background="@drawable/bg_chip_skill"
                        android:backgroundTint="#1AFFFFFF" />

                    <!-- Greeting & Subtitle Container -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="start">

                        <!-- Greeting Text -->
                        <TextView
                            android:id="@+id/greeting_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_on_accent"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            style="@style/TextAppearance.AU.Title" />

                        <!-- Subtitle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Discover skilled AU students"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            style="@style/TextAppearance.AU.Body" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Search Bar -->
            <EditText
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_bar_height"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginEnd="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_md"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="@dimen/space_sm"
                app:drawableTint="@color/text_tertiary"
                android:hint="Search AU students by skill..."
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                style="@style/TextAppearance.AU.Body" />

            <!-- Featured Mentors Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="10dp"
                android:text="Featured Mentors"
                android:textAllCaps="true"
                style="@style/TextAppearance.AU.Label" />

            <!-- Horizontal RecyclerView for Featured Mentors -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/featured_mentors_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_lg" />

            <!-- All AU Mentors Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_md"
                android:layout_marginBottom="10dp"
                android:text="All AU Mentors"
                android:textAllCaps="true"
                style="@style/TextAppearance.AU.Label" />

            <!-- Vertical RecyclerView for All Mentors -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/all_mentors_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Post Request -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_post_request"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Post Request"
        app:backgroundTint="@color/accent_primary"
        app:tint="@color/text_on_accent"
        app:elevation="2dp"
        app:fabCustomSize="52dp"
        app:maxImageSize="24dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.FAB" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
