<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/bg_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:tint="@color/text_primary"
                android:contentDescription="Back"
                android:padding="6dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Post a Request"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                style="@style/TextAppearance.AU.Title" />
        </RelativeLayout>

        <!-- Sharp bottom border for Toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light" />

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardBackgroundColor="@color/bg_card"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Skill Needed Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SKILL NEEDED"
                    android:layout_marginBottom="6dp"
                    style="@style/TextAppearance.AU.Label" />

                <!-- Skill Needed EditText -->
                <EditText
                    android:id="@+id/et_skill_needed"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. Flutter, AutoCAD, Calculus"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/edit_text_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:layout_marginBottom="16dp"
                    style="@style/TextAppearance.AU.Body" />

                <!-- Description Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPTION"
                    android:layout_marginBottom="6dp"
                    style="@style/TextAppearance.AU.Label" />

                <!-- Description EditText -->
                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Describe what you need help with..."
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/edit_text_bg"
                    android:padding="12dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="16dp"
                    style="@style/TextAppearance.AU.Body" />

                <!-- Urgency Spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="URGENCY LEVEL"
                    android:layout_marginBottom="6dp"
                    style="@style/TextAppearance.AU.Label" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_urgency"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="40dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_right"
                        android:rotation="90"
                        app:tint="@color/text_tertiary"
                        android:contentDescription="Dropdown" />
                </FrameLayout>

                <!-- Department Spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="YOUR DEPARTMENT"
                    android:layout_marginBottom="6dp"
                    style="@style/TextAppearance.AU.Label" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_department"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="40dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_right"
                        android:rotation="90"
                        app:tint="@color/text_tertiary"
                        android:contentDescription="Dropdown" />
                </FrameLayout>

                <!-- Semester Spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="YOUR SEMESTER"
                    android:layout_marginBottom="6dp"
                    style="@style/TextAppearance.AU.Label" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="24dp">

                    <Spinner
                        android:id="@+id/spinner_semester"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="40dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_right"
                        android:rotation="90"
                        app:tint="@color/text_tertiary"
                        android:contentDescription="Dropdown" />
                </FrameLayout>

                <!-- Submit Button -->
                <TextView
                    android:id="@+id/btn_submit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Submit Request"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"
                    style="@style/PrimaryButton" />

                <!-- Helper Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Your request will be visible to all AU students"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    style="@style/TextAppearance.AU.Caption" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
