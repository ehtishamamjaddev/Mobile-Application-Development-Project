<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary"
    android:padding="@dimen/space_lg">

    <!-- Top 55% Illustration Container -->
    <FrameLayout
        android:id="@+id/illustration_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.55"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Circular Illustration Background Badge -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_chip_skill" />

        <!-- Large Emoji Onboarding Icon -->
        <TextView
            android:id="@+id/slide_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="64sp" />

    </FrameLayout>

    <!-- Bottom 45% Text Container -->
    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="@dimen/space_md"
        app:layout_constraintTop_toBottomOf="@id/illustration_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/slide_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="@dimen/space_md"
            style="@style/TextAppearance.AU.Heading" />

        <!-- Description -->
        <TextView
            android:id="@+id/slide_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_sm"
            style="@style/TextAppearance.AU.Body" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
