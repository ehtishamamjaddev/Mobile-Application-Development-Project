<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ── Text Appearances (DM Sans) ── -->
    <style name="TextAppearance.AU.Display" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AU.Heading" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item> <!-- SemiBold 600 -->
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AU.Title" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item> <!-- SemiBold 600 -->
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AU.Subtitle" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">normal</item> <!-- Medium 500 -->
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.AU.Body" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item> <!-- Regular 400 -->
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AU.Caption" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item> <!-- Medium 500 -->
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="TextAppearance.AU.Label" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item> <!-- SemiBold 600 -->
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.AU.Badge" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item> <!-- Bold 700 -->
    </style>

    <style name="TextAppearance.AU.Button" parent="android:TextAppearance">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item> <!-- SemiBold 600 -->
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:letterSpacing">0.02</item>
    </style>


    <!-- ── Card Style ── -->
    <style name="AU.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="android:elevation">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="AUCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>


    <!-- ── Section Header ── -->
    <style name="SectionHeader">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:paddingTop">@dimen/spacing_lg</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Subtitle ── -->
    <style name="SubtitleText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Skill Chip ── -->
    <style name="SkillChip">
        <item name="android:background">@drawable/bg_chip_skill</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:paddingStart">@dimen/chip_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/chip_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/chip_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/chip_padding_vertical</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Department Badge ── -->
    <style name="DeptBadge">
        <item name="android:background">@drawable/bg_chip_dept</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/badge_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/badge_padding_vertical</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Primary Button ── -->
    <style name="PrimaryButton">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/spacing_xl</item>
        <item name="android:paddingEnd">@dimen/spacing_xl</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="SecondaryButton">
        <item name="android:background">@drawable/bg_button_outlined</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/spacing_xl</item>
        <item name="android:paddingEnd">@dimen/spacing_xl</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Urgency Badges ── -->
    <style name="UrgencyBadgeHigh">
        <item name="android:background">@drawable/bg_badge_high</item>
        <item name="android:textColor">@color/color_error</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="UrgencyBadgeMedium">
        <item name="android:background">@drawable/bg_badge_medium</item>
        <item name="android:textColor">@color/color_warning</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="UrgencyBadgeLow">
        <item name="android:background">@drawable/bg_badge_low</item>
        <item name="android:textColor">@color/color_success</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Input Field Style ── -->
    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:padding">14dp</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="AU.Input" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Onboarding Title ── -->
    <style name="OnboardingTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>


    <!-- ── Onboarding Description ── -->
    <style name="OnboardingDesc">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:gravity">center</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <!-- Shape Appearance Overlays -->
    <style name="ShapeAppearance.FAB" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>
